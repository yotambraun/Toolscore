name: Toolscore

# Replays your approved tool-call snapshots on every push / PR.
# Snapshots are recorded and approved locally; CI only replays them, so a
# missing or unapproved snapshot fails the build (never auto-records in CI).

on:
  push:
    branches: [main]
  pull_request:

jobs:
  toolscore:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install tool-scorer pytest
          # TODO: install your agent's own dependencies here, e.g.
          # pip install -r requirements.txt

      - name: Run Toolscore snapshot tests
        run: pytest tests/ -q
