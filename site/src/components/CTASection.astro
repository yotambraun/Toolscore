---
import { site, url } from '../data/site';
import Button from './Button.astro';
import InstallCommand from './InstallCommand.astro';

interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = 'Grade your tool-calling in seconds',
  sub = 'Install it, point it at a server or an agent, and read the verdict. Free, deterministic, offline.',
} = Astro.props;
---

<section class="section">
  <div class="wrap">
    <div
      class="relative overflow-hidden rounded-3xl border border-line2/50 bg-surface/70 px-6 py-14 text-center shadow-glow-soft sm:px-12"
    >
      <div
        class="pointer-events-none absolute inset-x-0 -top-24 mx-auto h-48 w-[44rem] max-w-full rounded-full bg-brandgrad opacity-[0.10] blur-3xl"
      >
      </div>

      <h2 class="h2 mx-auto max-w-2xl">{heading}</h2>
      <p class="lead mx-auto mt-4 max-w-xl">{sub}</p>

      <div class="mx-auto mt-8 grid max-w-md gap-2.5 text-left">
        <InstallCommand cmd={site.installPip} />
        <InstallCommand cmd={site.installUvx} />
      </div>

      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <Button href={url('quickstart')} variant="primary">Read the quickstart</Button>
        <Button href={site.repo} variant="secondary" external>Star on GitHub</Button>
        <Button href={site.pypi} variant="ghost" external>View on PyPI →</Button>
      </div>
    </div>
  </div>
</section>
