---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import InstallCommand from '../components/InstallCommand.astro';
import CodeBlock from '../components/CodeBlock.astro';
import CTASection from '../components/CTASection.astro';
import Button from '../components/Button.astro';
import { entryPoints, ciSnippet, site, url } from '../data/site';
---

<BaseLayout
  title="Quickstart"
  description="Get started with Toolscore in 60 seconds: pip install tool-scorer, then toolscore demo, toolscore mcp test, or toolscore eval. Plus a copy-paste GitHub Actions CI snippet."
>
  <PageHeader
    eyebrow="60-second start"
    title="Up and running in <span class='brand-text'>60 seconds</span>"
    sub="Install it, pick one of three entry points, and read the verdict. No API key, no cloud, no per-test bill."
  >
    <div class="mt-8 max-w-md">
      <InstallCommand cmd={site.installPip} label="Install" />
    </div>
  </PageHeader>

  <!-- Three entry points -->
  <section class="section">
    <div class="wrap">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-3">Three ways in</p>
        <h2 class="h2">Pick an entry point</h2>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {
          entryPoints.map((e, i) => (
            <div class="card flex flex-col p-6">
              <span class="font-mono text-3xl font-bold text-line2">{`0${i + 1}`}</span>
              <h3 class="mt-3 text-lg font-semibold text-ink">{e.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{e.body}</p>
              <div class="mt-4 rounded-md border border-line/80 bg-bg/50 px-3 py-2.5 font-mono text-[12px] text-brand">
                <span class="text-faint">$</span> {e.cmd}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- The snapshot loop -->
  <section class="section">
    <div class="wrap grid items-start gap-10 lg:grid-cols-2">
      <div>
        <p class="eyebrow mb-3">The agent loop</p>
        <h2 class="h2">Scaffold, record, approve, replay</h2>
        <p class="lead mt-4">
          <code class="rounded bg-elevated px-1.5 py-0.5 font-mono text-sm text-brand">toolscore init</code>
          detects your framework and writes a passing pytest suite plus a CI workflow. From there
          it's record once, approve, and replay forever.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href={url('agents')} variant="secondary">More on testing agents →</Button>
        </div>
      </div>
      <CodeBlock
        title="the whole loop"
        lang="bash"
        code={`toolscore init          # scaffold a passing pytest suite
pytest                  # records snapshots
toolscore approve --all # bless them as the baseline
pytest                  # replays — and fails on drift`}
      />
    </div>
  </section>

  <!-- CI snippet -->
  <section class="section">
    <div class="wrap">
      <div class="mb-8 max-w-2xl">
        <p class="eyebrow mb-3">Wire it into CI</p>
        <h2 class="h2">A GitHub Actions gate, copy-paste</h2>
        <p class="lead mt-4">
          Drop this workflow in to grade your MCP server on every push and PR. It fails the build
          below a B and writes the verdict to the run summary.
        </p>
      </div>

      <CodeBlock title=".github/workflows/toolscore.yml" lang="yaml" code={ciSnippet} />

      <p class="mt-4 text-sm text-muted">
        Prefer the prebuilt action? Use <a
          class="text-brand hover:underline"
          href={site.repo}>yotambraun/toolscore@v1</a
        > with <code class="font-mono text-brand">mcp-command</code> and
        <code class="font-mono text-brand">mcp-fail-under</code> inputs — or
        <code class="font-mono text-brand">gold-file</code> / <code class="font-mono text-brand">trace-file</code>
        for gold-standard evaluation.
      </p>
    </div>
  </section>

  <!-- Learn more -->
  <section class="section">
    <div class="wrap">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-3">Go deeper</p>
        <h2 class="h2">Learn more</h2>
      </div>

      <div class="mx-auto mt-10 grid max-w-4xl gap-5 sm:grid-cols-3">
        <a
          href={site.docs}
          target="_blank"
          rel="noopener"
          class="card flex flex-col p-6 transition-colors hover:border-brand/40"
        >
          <h3 class="text-lg font-semibold text-ink">API docs</h3>
          <p class="mt-2 flex-1 text-sm text-muted">
            Full API reference and guides on Read the Docs.
          </p>
          <span class="mt-4 font-mono text-xs text-brand">tool-scorer.readthedocs.io →</span>
        </a>
        <a
          href={site.repo}
          target="_blank"
          rel="noopener"
          class="card flex flex-col p-6 transition-colors hover:border-brand/40"
        >
          <h3 class="text-lg font-semibold text-ink">GitHub</h3>
          <p class="mt-2 flex-1 text-sm text-muted">
            Source, the TUTORIAL.md walkthrough, examples, and the GitHub Action.
          </p>
          <span class="mt-4 font-mono text-xs text-brand">github.com/yotambraun/Toolscore →</span>
        </a>
        <a
          href={site.pypi}
          target="_blank"
          rel="noopener"
          class="card flex flex-col p-6 transition-colors hover:border-brand/40"
        >
          <h3 class="text-lg font-semibold text-ink">PyPI</h3>
          <p class="mt-2 flex-1 text-sm text-muted">
            The package, install extras, and version history.
          </p>
          <span class="mt-4 font-mono text-xs text-brand">pypi.org/project/tool-scorer →</span>
        </a>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>
