---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import ComparisonMatrix from '../components/ComparisonMatrix.astro';
import CTASection from '../components/CTASection.astro';
import { compareBestAt } from '../data/site';
---

<BaseLayout
  title="Compare"
  description="Toolscore vs DeepEval, LangChain agentevals, EvalView, and mcp-eval — a confident capability matrix. The deterministic, offline, $0-per-run, snapshot-native health-check with an MCP-server scorecard."
>
  <PageHeader
    eyebrow="Positioning"
    title="Toolscore vs <span class='brand-text'>the field</span>"
    sub="Eval platforms and observability tools watch your agent in production across many quality dimensions. Toolscore does one thing well: it's the deterministic, in-CI health-check for tool-calling — for free, in your test suite. Here's where each tool shines."
  />

  <!-- The matrix -->
  <section class="section">
    <div class="wrap">
      <div class="mb-8 max-w-2xl">
        <p class="eyebrow mb-3">Capability matrix</p>
        <h2 class="h2">What's built in, at a glance</h2>
        <p class="lead mt-4">
          A fair read on capabilities, not accuracy. Toolscore's edge is being deterministic,
          offline, snapshot-native, and the only one that ships an MCP-server scorecard.
        </p>
      </div>

      <ComparisonMatrix />
    </div>
  </section>

  <!-- Best at -->
  <section class="section">
    <div class="wrap">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-3">What each is best at</p>
        <h2 class="h2">Use the right tool — often more than one</h2>
        <p class="lead mx-auto mt-4 max-w-xl">
          These aren't rivals so much as different jobs. Toolscore is the one you put in CI; pair it
          with an eval or observability platform for production monitoring.
        </p>
      </div>

      <div class="mt-12 grid gap-5 md:grid-cols-2">
        {
          compareBestAt.map((t) => (
            <div
              class:list={[
                'card flex flex-col p-7',
                t.self && 'border-brand/40 shadow-glow-soft',
              ]}
            >
              <div class="flex items-center gap-2">
                {t.self && <span class="h-2 w-2 rounded-full bg-brand" />}
                <h3 class:list={['text-xl font-bold', t.self ? 'text-brand' : 'text-ink']}>{t.name}</h3>
              </div>
              <p class="mt-3 text-pretty text-muted">{t.best}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Closing positioning -->
  <section class="section">
    <div class="wrap">
      <div class="card mx-auto max-w-3xl p-8 text-center sm:p-10">
        <p class="eyebrow mb-3">The bottom line</p>
        <p class="text-balance text-xl font-semibold leading-relaxed text-ink sm:text-2xl">
          Toolscore verifies your agent calls the right tools, with the right arguments, in the
          right order — and grades whether an MCP server can be used at all —
          <span class="brand-text">deterministically, offline, before you ship.</span>
        </p>
      </div>
    </div>
  </section>

  <CTASection
    heading="Add the deterministic gate to your CI"
    sub="pip install tool-scorer and fail the build the moment tool-calling drifts."
  />
</BaseLayout>
