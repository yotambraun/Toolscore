---
import { compareTools, compareRows } from '../data/site';

// Cell renderer: yes (brand check), partial (amber dot), no (faint dash).
const cell = (v: boolean | 'partial') => {
  if (v === true) return { sym: '✓', cls: 'text-gradeA', sr: 'Yes' };
  if (v === 'partial') return { sym: '~', cls: 'text-gradeC', sr: 'Partial' };
  return { sym: '–', cls: 'text-faint', sr: 'No' };
};
---

<div class="card scrollx overflow-x-auto">
  <table class="w-full min-w-[720px] border-collapse text-left text-sm">
    <thead>
      <tr class="border-b border-line">
        <th class="px-5 py-4 font-medium text-muted">Capability</th>
        {
          compareTools.map((t, i) => (
            <th
              class:list={[
                'px-4 py-4 text-center font-semibold',
                i === 0 ? 'text-brand' : 'text-muted',
              ]}
            >
              {i === 0 ? (
                <span class="inline-flex items-center gap-1.5">
                  <span class="h-1.5 w-1.5 rounded-full bg-brand" />
                  {t}
                </span>
              ) : (
                t
              )}
            </th>
          ))
        }
      </tr>
    </thead>
    <tbody>
      {
        compareRows.map((row) => (
          <tr class="border-b border-line/60 last:border-0">
            <td class="px-5 py-3.5 text-ink">{row.label}</td>
            {row.values.map((v, i) => {
              const c = cell(v);
              return (
                <td
                  class:list={[
                    'px-4 py-3.5 text-center font-mono text-base',
                    c.cls,
                    i === 0 && 'bg-brand/[0.04]',
                  ]}
                >
                  <span aria-hidden="true">{c.sym}</span>
                  <span class="sr-only">{c.sr}</span>
                </td>
              );
            })}
          </tr>
        ))
      }
    </tbody>
  </table>
</div>

<div class="mt-3 flex flex-wrap gap-x-5 gap-y-1.5 font-mono text-[11px] text-faint">
  <span><span class="text-gradeA">✓</span> built-in</span>
  <span><span class="text-gradeC">~</span> partial / via add-on</span>
  <span><span class="text-faint">–</span> not a focus</span>
</div>
